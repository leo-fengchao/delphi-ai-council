{
  "name": "delphi-ai-council",
  "version": "0.0.1",
  "type": "module",
  "description": "A browser extension that runs a multi-AI council across native AI web apps.",
  "license": "GPL-3.0-only",
  "author": "Fengchao",
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "ai",
    "delphi-method",
    "wxt",
    "react"
  ],
  "scripts": {
    "predev": "node -e \"require('fs').mkdirSync('.dev-chrome-profile',{recursive:true})\"",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "gen:config": "node scripts/gen-remote-config.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@xstate/react": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xstate": "^5.32.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@wxt-dev/module-react": "^1.1.3",
    "typescript": "^5.7.2",
    "wxt": "^0.19.27"
  },
  "pnpm": {
    "overrides": {
      "@vitejs/plugin-react": "^4.3.4"
    }
  }
}
